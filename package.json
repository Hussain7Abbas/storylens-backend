{
  "name": "storylens-backend",
  "private": true,
  "version": "0.0.0",
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "build": "bunx prisma generate && tsc && bun build --target bun --minify-whitespace --minify-syntax --outfile ./dist/index.js src/main.ts",
    "start": "bun ./dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "bunx prisma generate",
    "db:migrate:dev": "bunx prisma migrate dev",
    "db:migrate:deploy": "bunx prisma migrate deploy",
    "db:migrate:reset": "bunx prisma migrate reset",
    "db:seed": "bunx prisma db seed",
    "db:studio": "bunx prisma studio",
    "storage:seed": "bun run storage-seed/main.ts"
  },
  "dependencies": {
    "@elysiajs/bearer": "^1.4.1",
    "@elysiajs/cors": "^1.4.0",
    "@elysiajs/cron": "^1.4.1",
    "@elysiajs/openapi": "^1.4.3",
    "@openrouter/sdk": "^0.12.35",
    "@prisma/client": "^6.16.2",
    "@t3-oss/env-core": "^0.13.8",
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "chalk": "^5.6.2",
    "dayjs": "^1.11.18",
    "dotenv": "^17.2.2",
    "elysia": "^1.4.6",
    "jose": "^6.1.0",
    "jsdom": "^29.1.1",
    "linkedom": "^0.18.12",
    "prismabox": "^1.1.25",
    "sharp": "^0.34.4",
    "xpath": "^0.0.34",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.0.0",
    "@types/bun": "^1.2.22",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^24.5.2",
    "dunna": "^0.12.0",
    "prisma": "^6.16.2",
    "prisma-zod-generator": "^1.27.7",
    "typescript": "^5.9.2"
  }
}

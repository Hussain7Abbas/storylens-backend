# Server
PORT="BACKEND-PORT"
NODE_ENV="NODE-ENV"

# Auth
JWT_SECRET_KEY="JWT-SECRET-KEY"
AUTH_TOKEN_EXPIRATION="AUTH-TOKEN-EXPIRATION"

# Database
POSTGRES_USER="POSTGRES-USER"
POSTGRES_PASSWORD="POSTGRES-PASSWORD"
POSTGRES_DOMAIN="POSTGRES-DOMAIN"
POSTGRES_PORT="POSTGRES-PORT"
POSTGRES_DB="POSTGRES-DB"
DATABASE_URL="postgresql://$POSTGRES_USER:$POSTGRES_PASSWORD@$POSTGRES_DOMAIN:$POSTGRES_PORT/$POSTGRES_DB"
ROOT_USERNAME="ROOT-USERNAME"
ROOT_PASSWORD="ROOT-PASSWORD"

# Storage
STORAGE_IMGBB_API_KEY="STORAGE-IMGBB-API-KEY"

# AI (OpenRouter)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="google/gemini-2.5-flash"

# Server
PORT="BACKEND-PORT"
NODE_ENV="NODE-ENV"

# Auth (BetterAuth)
BETTER_AUTH_SECRET="your-random-secret-at-least-32-chars"
BETTER_AUTH_URL="http://localhost:3030"

# Database
DATABASE_URL="postgresql://POSTGRES_USER:POSTGRES_PASSWORD@POSTGRES_DOMAIN:POSTGRES_PORT/POSTGRES_DB"
ROOT_USERNAME="ROOT-USERNAME"
ROOT_PASSWORD="ROOT-PASSWORD"
ROOT_EMAIL="admin@example.com"

# Storage
STORAGE_IMGBB_API_KEY="STORAGE-IMGBB-API-KEY"

# AI (OpenRouter)
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="google/gemini-2.5-flash"
